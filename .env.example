# Example environment variables for ipsasel
# Copy this to `.env` and fill in real secrets (do NOT commit `.env`).

# --- Database (Supabase / Postgres) ---
# Option A: separate variables (used by scripts/app)
PGHOST=aws-1-us-east-1.pooler.supabase.com
PGPORT=6543
PGDATABASE=postgres
PGUSER=postgres.ridmsexeymlbmvspzied
PGPASSWORD=your_db_password_here

# Option B: connection string (alternative)
# DATABASE_URL=postgres://postgres.ridmsexeymlbmvspzied:your_db_password_here@aws-1-us-east-1.pooler.supabase.com:6543/postgres

# Compatibility with app's existing `.env` keys
DB_USER=william
DB_PASSWORD=ipsasel
DB_HOST=127.0.0.1
DB_NAME=ipsasel_db
DB_PORT=5432

# Migrations safety
ALLOW_DESTRUCTIVE_MIGRATIONS=false

# App settings
SESSION_SECRET=replace_with_secure_value
PORT=3000

# Admin (example placeholders — do not commit real credentials)
APP_ADMIN_USERNAME=inpsaseladmin
APP_ADMIN_NAME=Administrador INPSASEL
APP_ADMIN_PASSWORD_HASH=REPLACE_WITH_HASH

# Notes:
# - After copying to `.env`, set the real password in PGPASSWORD (or DB_PASSWORD).
# - To allow destructive migrations (files containing "recreate_schema"), set ALLOW_DESTRUCTIVE_MIGRATIONS=true
