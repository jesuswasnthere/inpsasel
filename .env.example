# ==============================================================
# Supabase — obtener desde: dashboard.supabase.com → Settings → API
# Copiar a .env.local y rellenar con valores reales (no commitear .env.local)
# ==============================================================

# Públicas — se exponen al navegador (prefijo NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Privada — SOLO usar en Server Actions y Route Handlers, NUNCA en el cliente
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ==============================================================
# Para: npm run types:db
# Obtener desde: dashboard.supabase.com → Settings → General → Project ID
# ==============================================================
SUPABASE_PROJECT_ID=xxxxxxxxxxxx
