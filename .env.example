# ==============================================================
# Supabase — dashboard.supabase.com → Settings → API
# Copiar a .env.local con los valores reales (no commitear .env.local)
# ==============================================================

# Públicas (prefijo NEXT_PUBLIC_ → visibles en el navegador)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Privada — SOLO en Server Actions/Route Handlers, NUNCA en el cliente
# dashboard.supabase.com → Settings → API → Secret key
SUPABASE_SECRET_KEY=sb_secret_...

# ==============================================================
# Para: npm run types:db  (extraído de la URL del proyecto)
# dashboard.supabase.com → Settings → General → Reference ID
# ==============================================================
SUPABASE_PROJECT_ID=xxxxxxxxxxxx
